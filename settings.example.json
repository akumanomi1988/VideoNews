{
  "api_keys": {
    "news_api": "YOUR_NEWS_API_KEY",
    "currents_api": "YOUR_CURRENTS_API_KEY",
    "pexels_api": "YOUR_PEXELS_API_KEY",
    "elevenlabs": "YOUR_ELEVENLABS_KEY"
  },
  "oauth": {
    "youtube": {
      "client_id": "YOUR_CLIENT_ID",
      "client_secret": "YOUR_CLIENT_SECRET",
      "redirect_uri": "http://localhost:8080/oauth2callback"
    },
    "tiktok": {
      "client_key": "YOUR_CLIENT_KEY",
      "client_secret": "YOUR_CLIENT_SECRET",
      "redirect_uri": "http://localhost:8080/tiktok/callback"
    }
  },
  "telegram": {
    "bot_token": "YOUR_BOT_TOKEN",
    "webhook_url": "https://akumanomi1988.example.com/webhook",
    "admin_chat_id": "YOUR_ADMIN_CHAT_ID"
  },
  "database": {
    "news_db": "processed_news.db",
    "users_db": "users.db",
    "backup_enabled": true,
    "backup_interval_hours": 24
  },
  "pipeline": {
    "default_type": "short",
    "parallel_processing": true,
    "memory_optimization": true,
    "cache_enabled": true,
    "temp_dir": ".temp",
    "output_dir": "output",
    "max_retries": 3,
    "timeout_seconds": 300
  },
  "video": {
    "short_form": {
      "aspect_ratio": "9:16",
      "target_duration": 60,
      "max_duration": 180,
      "resolution": "1080x1920",
      "fps": 30,
      "bitrate": "4M"
    },
    "long_form": {
      "aspect_ratio": "16:9",
      "target_duration": 600,
      "max_duration": 1200,
      "resolution": "1920x1080",
      "fps": 30,
      "bitrate": "8M"
    }
  },
  "tts": {
    "provider": "edge",
    "language": "en",
    "voice": "en-US-JennyNeural",
    "rate": 0,
    "pitch": 0,
    "optimize_for_low_vram": false,
    "fallback_providers": [
      "elevenlabs",
      "bark"
    ],
    "quota_management": {
      "elevenlabs_min_chars": 1000,
      "max_concurrent_requests": 3
    }
  },
  "news": {
    "sources": [
      "newsapi",
      "currents"
    ],
    "languages": [
      "en",
      "es"
    ],
    "categories": [
      "technology",
      "science",
      "business"
    ],
    "content_filters": {
      "min_length": 300,
      "max_length": 5000,
      "exclude_keywords": [
        "explicit",
        "nsfw"
      ],
      "require_image": true
    }
  },
  "media": {
    "image_generation": {
      "provider": "flux",
      "style_preset": "photographic",
      "model": "black-forest-labs/FLUX.1-schnell",
      "fallback_provider": "pexels"
    },
    "music": {
      "enabled": true,
      "volume": 0.3,
      "fade_duration": 3,
      "library_path": "Resources/Music"
    }
  },
  "monitoring": {
    "enabled": true,
    "log_level": "INFO",
    "metrics_enabled": true,
    "dashboard_port": 8050,
    "alert_on_error": true,
    "performance_tracking": true
  },
  "upload": {
    "platforms": {
      "youtube": {
        "enabled": true,
        "privacy": "public",
        "category_id": "22",
        "made_for_kids": false,
        "tags_enabled": true,
        "auto_thumbnails": true
      },
      "tiktok": {
        "enabled": true,
        "privacy": "public",
        "allow_comments": true,
        "allow_duet": true,
        "allow_stitch": true
      }
    },
    "scheduling": {
      "enabled": false,
      "timezone": "UTC",
      "optimal_times": [
        "14:00",
        "18:00",
        "20:00"
      ],
      "min_interval_hours": 4
    }
  }
}
